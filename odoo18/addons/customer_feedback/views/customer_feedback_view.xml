<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="view_customer_feedback_list" model="ir.ui.view">
        <field name="name">customer.feedback.list</field>
        <field name="model">customer.feedback</field>
        <field name="arch" type="xml">
            <list string="Customer Feedback">
                <field name="name"/>
                <field name="email"/>
                <field name="rating"/>
                <field name="date"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_customer_feedback_form" model="ir.ui.view">
        <field name="name">customer.feedback.form</field>
        <field name="model">customer.feedback</field>
        <field name="arch" type="xml">
            <form string="Customer Feedback">
                <sheet>
                    <group>
                        <group string="Customer Information">
                            <field name="name"/>
                            <field name="email"/>
                            <field name="rating"/>
                            <field name="date"/>
                        </group>
                        <group string="Status">
                            <field name="status"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Feedback">
                            <field name="feedback"/>
                        </page>
                        <page string="Internal Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_customer_feedback" model="ir.actions.act_window">
        <field name="name">Customer Feedback</field>
        <field name="res_model">customer.feedback</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_customer_feedback_root"
        name="Customer Feedback"
        sequence="100"/>

    <menuitem id="menu_customer_feedback_list"
        name="All Feedback"
        parent="menu_customer_feedback_root"
        action="action_customer_feedback"
        sequence="1"/>

</odoo>
